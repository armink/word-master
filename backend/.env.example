# 后端服务端口
PORT=3000

# 前端子路径部署时设置（需与 Vite 构建时的 VITE_BASE_URL 一致）
# 根路径部署留空或设为 /，子路径示例：/word-master/
VITE_BASE_URL=/

# 允许跨域的额外来源（生产环境前后端同源时无需配置）
# 仅当前端与后端分开部署时才需要填写，如：https://yourdomain.com
CORS_ORIGIN=

# 数据库文件路径（相对于 backend 目录）
DB_PATH=./data/word-test.db

# 讯飞开放平台配置（在 https://www.xfyun.cn 注册后获取）
XUNFEI_APP_ID=your_app_id_here
XUNFEI_API_KEY=your_api_key_here
XUNFEI_API_SECRET=your_api_secret_here

# DeepSeek API Key（用于自动生成方案C风格例句）
# 申请地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your_api_key_here
